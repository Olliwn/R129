* 06_full_board - cleaned for netlist_viewer
* Subcircuits inlined as simplified stubs (viewer only, not simulatable)

* === SUBCIRCUIT DEFINITIONS ===

.subckt TLP521 A K C E
D_led A K
R_opto C E 1k
.ends TLP521

.subckt TVS_1_5KE18A PLUS MINUS
D_tvs MINUS PLUS
.ends TVS_1_5KE18A

.subckt OKI78SR_5V VIN VOUT GND
R_out VIN VOUT 33m
R_q VIN GND 4k
C_out VOUT GND 22u
.ends OKI78SR_5V

.subckt LD1117V33 VIN VOUT GND
R_out VIN VOUT 20m
R_q VIN GND 1k
C_out VOUT GND 10u
.ends LD1117V33

.subckt CAR_DIAG_CHANNEL DIAG_PIN CAR_GND BLINK_CTL
V_bat bat_node CAR_GND DC 12
R_pullup bat_node ecu_out 680
R_base BLINK_CTL base_node 1k
Q_ecu ecu_out base_node CAR_GND NPN
R_wire ecu_out wire_mid 1
C_cable wire_mid CAR_GND 500p
R_contact wire_mid DIAG_PIN 0.1
.ends CAR_DIAG_CHANNEL

* === POWER SUPPLY ===
V_bat vin_raw 0 DC 12.0
R_fuse vin_raw vin_fused 50m
D_rpol vin_fused vin_prot
X_tvs vin_prot 0 TVS_1_5KE18A
C_in vin_prot 0 100u
X_buck vin_prot v5_bus 0 OKI78SR_5V
C_5v v5_bus 0 100n
X_ldo v5_bus v3_bus 0 LD1117V33
C_3v3 v3_bus 0 100n

* === Ch6: SRS ===
V_b6 bc6 0 DC 5
X_c6 dp6 0 bc6 CAR_DIAG_CHANNEL
R_rx6 dp6 oa6 1k
X_or6 oa6 0 mr6 0 TLP521
R_pu6 v3_bus mr6 13k
V_t6 tc6 0 DC 0
R_tr6 tc6 ta6 330
X_ot6 ta6 0 tc6c te6 TLP521
R_oc6 dp6 tc6c 1k
Q_d6 dp6 te6 0 NPN
R_bp6 te6 0 10k

* === Ch7: RB ===
V_b7 bc7 0 DC 5
X_c7 dp7 0 bc7 CAR_DIAG_CHANNEL
R_rx7 dp7 oa7 1k
X_or7 oa7 0 mr7 0 TLP521
R_pu7 v3_bus mr7 13k
